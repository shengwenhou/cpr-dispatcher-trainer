# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Node
node_modules/

# macOS
.DS_Store

# 金鑰與秘密 — 絕不提交
secrets/
*service-account*.json
*-key.json
.env
.env.*

# 私有筆記（本機專用，含私有路徑與機器資訊）
LOCAL_NOTES.md

# IDE / 編輯器
.vscode/
.idea/

# 執行期產物
*.log
sessions/
exports/

# spike 編譯產物（Swift 直編 binary，不入 repo）
spike/stt_spike
spike/*.dSYM/
*.o
*.swiftmodule

# spike 實測輸出（事件 JSONL，屬執行期產物，不入 repo）
spike/*.jsonl

# spike 實測音訊（--dump-audio 產物、失敗現場錄音等；可能含真人語音，
# 本 repo 為 PUBLIC，一律不入 repo）
spike/*.wav
spike/*.aiff
spike/*.caf

# TTS 合成中繼產物：Gemini 原始 24kHz raw wav，僅供本機重跑語速用，
# final wav（assets/audio/<locale>/*.wav）才入 repo
assets/audio/*/raw/

# 課堂資料落地（JSONL＋manifest，執行期產物，不入 repo）
data/
.claude/
